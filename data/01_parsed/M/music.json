      "references": [],
      "sub_groups": [
        {
          "name": "This musical sign occurs in the titles of Ps 32:1; 42:1; 44:1; 45:1; 52:1; 53:1; 54:1; 55:1; 74:1; 78:1; 88:1; 89:1; 142:1",
