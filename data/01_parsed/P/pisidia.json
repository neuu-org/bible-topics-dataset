  "definitions": [
    {
      "source": "EAS",
      "text": "A district in Asia Minor, to the north of Pamphylia. The Taurus range of mountains extends through it. Antioch, one of its chief cities, was twice visited by Paul (Acts 13:14; 14:21-24).",
      "extracted_refs": [
