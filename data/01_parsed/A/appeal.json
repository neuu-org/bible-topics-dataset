  "definitions": [
    {
      "source": "EAS",
      "text": "A reference of any case from an inferior to a superior court. Moses established in the wilderness a series of judicatories such that appeals could be made from a lower to a higher (Ex. 18:13-26.) Under the Roman law the most remarkable case of appeal is that of Paul from the tribunal of Festus at Caesarea to that of the emperor at Rome (Acts 25:11, 12, 21, 25). Paul availed himself of the privilege of a Roman citizen in this matter.",
      "extracted_refs": [
        {
          "book": "Exodus",
          "chapter": 18,
