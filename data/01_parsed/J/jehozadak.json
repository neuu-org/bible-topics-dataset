  "definitions": [
    {
      "source": "EAS",
      "text": "Jehovah-justified, the son of the high priest Seraiah at the time of the Babylonian exile (1 Chr. 6:14, 15). He was carried into captivity by Nebuchadnezzar, and probably died in Babylon. He was the father of Jeshua, or Joshua, who returned with Zerubbabel.",
      "extracted_refs": [
        {
          "book": "1 Chronicles",
          "chapter": 6,
