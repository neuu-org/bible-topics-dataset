  "definitions": [
    {
      "source": "EAS",
      "text": "Thanksgiving, referred to by Gamaliel in his speech before the council at Jerusalem (Acts 5:36). He headed an insurrection against the Roman authority. Beyond this nothing is known of him.",
      "extracted_refs": [
        {
          "book": "Acts",
