  "definitions": [
    {
      "source": "EAS",
      "text": "(Matt. 9:23), a flute-player. Such music was a usual accompaniment of funerals. In 2 Kings 3:15 it denotes a player on a stringed instrument.",
      "extracted_refs": [
        {
          "book": "Matthew",
          "chapter": 9,
          "verses": [
            23
          ],
          "verse_count": 1,
          "testament": "NT",
