  "definitions": [
    {
      "source": "EAS",
      "text": "Acacias, also called “Abel-shittim” (Num. 33:49), a plain or valley in the land of Moab where the Israelites were encamped after their two victories over Sihon and Og, at the close of their desert wanderings, and from which Joshua sent forth two spies (q.v.) “secretly” to “view” the land and Jericho (Josh. 2:1).",
      "extracted_refs": [
        {
          "book": "Numbers",
          "chapter": 33,
          "verses": [
            49
          ],
          "verse_count": 1,
          "testament": "OT",
