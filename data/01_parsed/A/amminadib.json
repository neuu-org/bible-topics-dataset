  "definitions": [
    {
      "source": "EAS",
      "text": "A person mentioned in Cant. 6:12, whose chariots were famed for their swiftness. It is rendered in the margin “my willing people,” and in the Revised Version “my princely people.”",
      "extracted_refs": [
