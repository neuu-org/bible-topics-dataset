  "type": "topic",
  "reference_groups": [
    {
      "name": "(In the A. V. this word occurs in O. T. Scriptures, cited below, and is the translation of the Hebrew word “sheol,” which signifies the unseen state)",
      "references": [],
      "sub_groups": []
    },
    {
      "name": "In the R. V. of O. T. it appears only in Isa 5:14; 14:9,15; 28:15,18; 57:9; Eze 31:16,17; 32:21,27; Am 9:2; Jon 2:2; Hab 2:5",
      "references": [
